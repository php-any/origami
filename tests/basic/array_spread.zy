namespace tests\basic;

// 测试基本的数组展开语法
$a1 = [1, 2, 3];
$a2 = [4, 5, 6];
$result = [...$a1, ...$a2];

if(count($result) == 6 && $result[0] == 1 && $result[1] == 2 && $result[2] == 3 && $result[3] == 4 && $result[4] == 5 && $result[5] == 6) {
    Log::info("基本数组展开测试通过");
} else {
    Log::fatal("基本数组展开测试失败");
}

// 测试展开和普通元素混合
$a3 = [10, 20];
$result2 = [...$a3, 30, 40];

if(count($result2) == 4 && $result2[0] == 10 && $result2[1] == 20 && $result2[2] == 30 && $result2[3] == 40) {
    Log::info("展开和普通元素混合测试通过");
} else {
    Log::fatal("展开和普通元素混合测试失败");
}

// 测试普通元素和展开混合
$a4 = [100, 200];
$result3 = [50, ...$a4, 300];

if(count($result3) == 4 && $result3[0] == 50 && $result3[1] == 100 && $result3[2] == 200 && $result3[3] == 300) {
    Log::info("普通元素和展开混合测试通过");
} else {
    Log::fatal("普通元素和展开混合测试失败");
}

// 测试多个数组展开
$a5 = [1];
$a6 = [2, 3];
$a7 = [4];
$result4 = [...$a5, ...$a6, ...$a7];

if(count($result4) == 4 && $result4[0] == 1 && $result4[1] == 2 && $result4[2] == 3 && $result4[3] == 4) {
    Log::info("多个数组展开测试通过");
} else {
    Log::fatal("多个数组展开测试失败");
}

// 测试空数组展开
$a8 = [];
$a9 = [1, 2];
$result5 = [...$a8, ...$a9];

if(count($result5) == 2 && $result5[0] == 1 && $result5[1] == 2) {
    Log::info("空数组展开测试通过");
} else {
    Log::fatal("空数组展开测试失败");
}

// 测试展开空数组
$a10 = [1, 2];
$a11 = [];
$result6 = [...$a10, ...$a11];

if(count($result6) == 2 && $result6[0] == 1 && $result6[1] == 2) {
    Log::info("展开空数组测试通过");
} else {
    Log::fatal("展开空数组测试失败");
}

// 测试复杂混合场景
$a12 = [1, 2];
$a13 = [3, 4];
$result7 = [0, ...$a12, 5, ...$a13, 6];

if(count($result7) == 7 && $result7[0] == 0 && $result7[1] == 1 && $result7[2] == 2 && $result7[3] == 5 && $result7[4] == 3 && $result7[5] == 4 && $result7[6] == 6) {
    Log::info("复杂混合场景测试通过");
} else {
    Log::fatal("复杂混合场景测试失败");
}

// 测试单个元素数组展开
$a14 = [42];
$result8 = [...$a14];

if(count($result8) == 1 && $result8[0] == 42) {
    Log::info("单个元素数组展开测试通过");
} else {
    Log::fatal("单个元素数组展开测试失败");
}

// 测试尾随逗号
$a15 = [1, 2];
$a16 = [3, 4];
$result9 = [
    ...$a15,
    ...$a16,
];

if(count($result9) == 4 && $result9[0] == 1 && $result9[1] == 2 && $result9[2] == 3 && $result9[3] == 4) {
    Log::info("尾随逗号测试通过");
} else {
    Log::fatal("尾随逗号测试失败");
}

Log::info("✅ 数组展开语法测试完成");

