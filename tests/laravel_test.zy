namespace tests;

$pass = 0; $fail = 0;
function check($name, $ok) { global $pass, $fail;
    if ($ok) { $pass++; Log::info("[PASS] $name"); }
    else { $fail++; Log::fatal("[FAIL] $name"); }
}

Log::info("====== Laravel 请求生命周期测试 ======");

$_ENV['APP_KEY'] = 'base64:7X1ZM4KlTvQVXom4E7u5YftL4H7NjbZQJGJ1lCqVUWs=';
putenv('APP_KEY=base64:7X1ZM4KlTvQVXom4E7u5YftL4H7NjbZQJGJ1lCqVUWs=');
check("环境变量", true);

require __DIR__ . '/../laravel/vendor/autoload.php';
check("Composer autoload", true);

$app = require_once __DIR__ . '/../laravel/bootstrap/app.php';
check("Application", true);
check("\$app instanceof ArrayAccess", $app instanceof ArrayAccess);

(new \Illuminate\Foundation\Bootstrap\LoadConfiguration())->bootstrap($app);
check("LoadConfiguration", true);

$config = $app['config'];
check("\$app['config']", true);

$paths = $config->get('cors.paths', []);
$count = 0; foreach ($paths as $p) { $count++; }
check("foreach config->get($count 项)", true);

(new \Illuminate\Foundation\Bootstrap\RegisterFacades())->bootstrap($app);
check("RegisterFacades", true);

$kernel = $app->make(\Illuminate\Contracts\Http\Kernel::class);
check("Kernel", true);

$request = new \Illuminate\Http\Request([], [], [], [], [], [
    'REQUEST_METHOD' => 'GET', 'REQUEST_URI' => '/',
    'HTTP_HOST' => 'localhost', 'SERVER_NAME' => 'localhost',
    'SERVER_PORT' => '80',
    'SCRIPT_FILENAME' => __DIR__ . '/../laravel/public/index.php',
]);
check("测试请求", true);

try {
    $response = $kernel->handle($request);
    check("Kernel->handle() 状态码: " . $response->getStatusCode(), true);
    Log::info("[INFO] 响应: " . substr($response->getContent() ?? '', 0, 200));
} catch (\Exception $e) {
    check("Kernel->handle: " . $e->getMessage(), false);
    Log::info("[TRACE] " . $e->getTraceAsString());
}

Log::info("====== $pass 通过, $fail 失败 ======");
if ($fail > 0) { Log::fatal("有 $fail 个测试失败"); }
