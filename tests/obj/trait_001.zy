namespace tests\obj;

// 测试基本的 trait 定义和使用
trait Loggable {
    public function log($message) {
        return "Log: " . $message;
    }
}

class User {
    use Loggable;
    
    private $name;
    
    public function __construct($name) {
        $this->name = $name;
    }
    
    public function getName() {
        return $this->name;
    }
}

$user = new User("Alice");
$result = $user->log("User created");
if($result == "Log: User created") {
    Log::info("trait 方法调用成功");
} else {
    Log::fatal("trait 方法调用失败: " . $result);
}

if($user->getName() == "Alice") {
    Log::info("类方法调用成功");
} else {
    Log::fatal("类方法调用失败");
}

